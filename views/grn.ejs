<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> &middot; Supermarket POS</title>
    <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>

    <!-- ========== Top bar ========== -->
    <header class="topbar">
        <div class="topbar-inner">
            <a href="/" class="brand">
                <span class="brand-mark">▤</span>
                <span class="brand-name">Supermarket POS</span>
            </a>
            <nav class="topnav">
                <a href="/pos">Till</a>
                <a href="/products">Products</a>
                <a href="/suppliers">Suppliers</a>
                <a href="/grn" class="active">Goods received</a>
                <a href="/reports/daily">Reports</a>
            </nav>
            <div class="topbar-user">
                <span class="user-name"><%= currentUser.full_name %></span>
                <span class="user-role"><%= currentUser.role %></span>
                <a href="/logout" class="logout-link">Sign out</a>
            </div>
        </div>
    </header>

    <!-- ========== Flash ========== -->
    <% if (flashSuccess && flashSuccess.length > 0) { %>
        <div class="flash flash-success"><%= flashSuccess[0] %></div>
    <% } %>
    <% if (flashError && flashError.length > 0) { %>
        <div class="flash flash-error"><%= flashError[0] %></div>
    <% } %>

    <!-- ========== Main content ========== -->
    <main class="page">

        <div class="page-header">
            <div>
                <h1>Goods received</h1>
                <p class="page-subtitle">
                    <% if (grns.length === 0) { %>
                        No goods received yet
                    <% } else { %>
                        <%= grns.length %> delivery<%= grns.length === 1 ? '' : 'ies' %> recorded
                    <% } %>
                </p>
            </div>
            <a href="/grn/new" class="btn-primary">+ Record new delivery</a>
        </div>

        <% if (grns.length === 0) { %>

            <div class="empty-state">
                <p>When stock arrives from a supplier, record it here so the inventory is updated.</p>
                <a href="/grn/new" class="btn-primary">Record your first delivery</a>
            </div>

        <% } else { %>

            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Reference</th>
                            <th>Received</th>
                            <th>Supplier</th>
                            <th>Their invoice</th>
                            <th class="num">Lines</th>
                            <th class="num">Units</th>
                            <th class="num">Total</th>
                            <th>By</th>
                            <th class="actions-col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% grns.forEach(g => { %>
                            <tr class="<%= g.status === 'voided' ? 'row-inactive' : '' %>">
                                <td>
                                    <div class="cell-name"><%= g.reference %></div>
                                    <% if (g.status === 'voided') { %>
                                        <div class="cell-meta">VOIDED</div>
                                    <% } %>
                                </td>
                                <td>
                                    <div><%= formatDate(g.received_at) %></div>
                                </td>
                                <td>
                                    <div><%= g.supplier_name || '—' %></div>
                                </td>
                                <td>
                                    <% if (g.supplier_invoice) { %>
                                        <span class="cell-meta"><%= g.supplier_invoice %></span>
                                    <% } else { %>
                                        <span class="cell-meta">—</span>
                                    <% } %>
                                </td>
                                <td class="num"><%= g.line_count %></td>
                                <td class="num"><%= g.total_units || 0 %></td>
                                <td class="num"><strong><%= formatRand(g.total_cents) %></strong></td>
                                <td>
                                    <div class="cell-meta"><%= g.received_by_name %></div>
                                </td>
                                <td class="actions-col">
                                    <a href="/grn/<%= g.id %>" class="btn-tiny">View</a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

        <% } %>

    </main>

    <footer class="sitefoot">
        <span>Supermarket POS &middot; Phase 2</span>
        <span>&copy; 2026</span>
    </footer>

</body>
</html>
