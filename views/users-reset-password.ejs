<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> &middot; Supermarket POS</title>
    <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>

    <!-- ========== Top bar ========== -->
    <header class="topbar">
        <div class="topbar-inner">
            <a href="/" class="brand">
                <span class="brand-mark">▤</span>
                <span class="brand-name">Supermarket POS</span>
            </a>
            <nav class="topnav">
                <a href="/pos">Till</a>
                <a href="/products">Products</a>
                <a href="/suppliers">Suppliers</a>
                <a href="/grn">Goods received</a>
                <a href="/stock-adjustments">Adjustments</a>
                <a href="/reports/daily">Reports</a>
                <a href="/users" class="active">Users</a>
            </nav>
            <div class="topbar-user">
                <span class="user-name"><%= currentUser.full_name %></span>
                <span class="user-role"><%= currentUser.role %></span>
                <a href="/logout" class="logout-link">Sign out</a>
            </div>
        </div>
    </header>

    <!-- ========== Flash ========== -->
    <% if (flashError && flashError.length > 0) { %>
        <div class="flash flash-error"><%= flashError[0] %></div>
    <% } %>

    <!-- ========== Main content ========== -->
    <main class="page">

        <div class="form-page">

            <div class="form-header">
                <h1>Reset password</h1>
                <a href="/users" class="form-back">← Back to users</a>
            </div>

            <div class="reset-target-card">
                <div class="reset-target-label">Resetting password for:</div>
                <div class="reset-target-name"><%= user.full_name %></div>
                <div class="reset-target-meta">
                    <code><%= user.username %></code>
                    <% if (user.role === 'manager') { %>
                        <span class="role-pill role-manager">Manager</span>
                    <% } else { %>
                        <span class="role-pill role-cashier">Cashier</span>
                    <% } %>
                </div>
            </div>

            <form method="POST" action="/users/<%= user.id %>/reset-password" class="product-form">

                <div class="form-grid">

                    <label class="field">
                        <span class="field-label">New password <span class="req">*</span></span>
                        <input
                            type="password"
                            name="password"
                            required
                            minlength="8"
                            placeholder="Minimum 8 characters"
                            autocomplete="new-password"
                        />
                        <span class="field-hint">At least 8 characters.</span>
                    </label>

                    <label class="field">
                        <span class="field-label">Confirm new password <span class="req">*</span></span>
                        <input
                            type="password"
                            name="confirm_password"
                            required
                            minlength="8"
                            placeholder="Re-enter new password"
                            autocomplete="new-password"
                        />
                    </label>

                </div>

                <div class="form-actions">
                    <a href="/users" class="btn-secondary">Cancel</a>
                    <button type="submit" class="btn-primary">Set new password</button>
                </div>

            </form>

            <div class="form-side-notes">
                <p>
                    After resetting, <strong><%= user.full_name %></strong> will need to use
                    the new password on their next login. Tell them the password securely
                    (in person or via a secure channel).
                </p>
            </div>

        </div>

    </main>

    <footer class="sitefoot">
        <span>Supermarket POS &middot; Phase 2</span>
        <span>&copy; 2026</span>
    </footer>

</body>
</html>
