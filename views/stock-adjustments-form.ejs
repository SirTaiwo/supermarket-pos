<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> &middot; Supermarket POS</title>
    <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>

    <!-- ========== Top bar ========== -->
    <header class="topbar">
        <div class="topbar-inner">
            <a href="/" class="brand">
                <span class="brand-mark">▤</span>
                <span class="brand-name">Supermarket POS</span>
            </a>
            <nav class="topnav">
                <a href="/pos">Till</a>
                <a href="/products">Products</a>
                <a href="/suppliers">Suppliers</a>
                <a href="/grn">Goods received</a>
                <a href="/stock-adjustments" class="active">Adjustments</a>
                <a href="/reports/daily">Reports</a>
            </nav>
            <div class="topbar-user">
                <span class="user-name"><%= currentUser.full_name %></span>
                <span class="user-role"><%= currentUser.role %></span>
                <a href="/logout" class="logout-link">Sign out</a>
            </div>
        </div>
    </header>

    <!-- ========== Flash ========== -->
    <% if (flashError && flashError.length > 0) { %>
        <div class="flash flash-error"><%= flashError[0] %></div>
    <% } %>

    <!-- ========== Main content ========== -->
    <main class="page">

        <div class="adj-form-page">

            <div class="form-header">
                <h1>Record stock adjustment</h1>
                <a href="/stock-adjustments" class="form-back">← Back to adjustments</a>
            </div>

            <form method="POST" action="/stock-adjustments" id="adj-form" class="adj-form">

                <div class="form-grid">

                    <!-- Product selector -->
                    <label class="field field-full">
                        <span class="field-label">Product <span class="req">*</span></span>
                        <select name="product_id" id="product-select" required>
                            <option value="">-- Select product --</option>
                            <% products.forEach(p => { %>
                                <option value="<%= p.id %>" data-stock="<%= p.stock_qty %>" data-sku="<%= p.sku %>">
                                    <%= p.name %> (<%= p.sku %>) — stock: <%= p.stock_qty %>
                                </option>
                            <% }) %>
                        </select>
                    </label>

                    <!-- Reason -->
                    <label class="field">
                        <span class="field-label">Reason <span class="req">*</span></span>
                        <select name="reason_id" id="reason-select" required>
                            <option value="">-- Select reason --</option>
                            <% reasons.forEach(r => { %>
                                <option value="<%= r.id %>" data-direction="<%= r.direction %>" data-code="<%= r.code %>">
                                    <%= r.name %> (<%= r.code %>)
                                </option>
                            <% }) %>
                        </select>
                        <span class="field-hint" id="reason-hint">Pick a reason to set the direction</span>
                    </label>

                    <!-- Quantity change -->
                    <label class="field">
                        <span class="field-label">Quantity change <span class="req">*</span></span>
                        <input
                            type="number"
                            name="quantity_change"
                            id="qty-input"
                            placeholder="e.g. -4 (write off 4 units)"
                            step="1"
                            required
                        />
                        <span class="field-hint" id="qty-hint">
                            Use negative for stock OUT (damage, expiry, theft); positive for stock IN (found).
                        </span>
                    </label>

                    <!-- Live preview -->
                    <div class="field field-full">
                        <span class="field-label">Preview</span>
                        <div class="adj-preview" id="preview-box">
                            <span class="preview-empty">Select a product and enter a quantity to see the impact</span>
                        </div>
                    </div>

                    <!-- Note -->
                    <label class="field field-full">
                        <span class="field-label">Note</span>
                        <textarea
                            name="note"
                            rows="3"
                            placeholder="e.g. Four 250g cheese blocks expired today; supplier credit pending."
                        ></textarea>
                        <span class="field-hint">Optional but recommended for audit clarity.</span>
                    </label>

                </div>

                <div class="form-actions">
                    <a href="/stock-adjustments" class="btn-secondary">Cancel</a>
                    <button type="submit" class="btn-primary" id="submit-btn" disabled>
                        Record adjustment
                    </button>
                </div>

            </form>

        </div>

    </main>

    <footer class="sitefoot">
        <span>Supermarket POS &middot; Phase 2</span>
        <span>&copy; 2026</span>
    </footer>


    <!-- ===== Inline JavaScript ===== -->
    <script>
        (function() {
            "use strict";

            const productSelect = document.getElementById("product-select");
            const reasonSelect  = document.getElementById("reason-select");
            const qtyInput      = document.getElementById("qty-input");
            const previewBox    = document.getElementById("preview-box");
            const reasonHint    = document.getElementById("reason-hint");
            const submitBtn     = document.getElementById("submit-btn");


            // React to changes on any of the inputs
            productSelect.addEventListener("change", updatePreview);
            reasonSelect.addEventListener("change", () => {
                updateReasonHint();
                updatePreview();
            });
            qtyInput.addEventListener("input", updatePreview);


            function updateReasonHint() {
                const opt = reasonSelect.options[reasonSelect.selectedIndex];
                if (!opt || !opt.value) {
                    reasonHint.textContent = "Pick a reason to set the direction";
                    reasonHint.style.color = "";
                    return;
                }
                const direction = opt.dataset.direction;
                if (direction === "negative") {
                    reasonHint.textContent = "This reason DECREASES stock. Quantity must be negative.";
                    reasonHint.style.color = "#b91c1c";
                } else if (direction === "positive") {
                    reasonHint.textContent = "This reason INCREASES stock. Quantity must be positive.";
                    reasonHint.style.color = "#15803d";
                } else {
                    reasonHint.textContent = "This reason allows positive OR negative quantity changes.";
                    reasonHint.style.color = "#475569";
                }
            }


            function updatePreview() {
                const prodOpt   = productSelect.options[productSelect.selectedIndex];
                const reasonOpt = reasonSelect.options[reasonSelect.selectedIndex];
                const qty       = parseInt(qtyInput.value, 10);

                if (!prodOpt || !prodOpt.value) {
                    previewBox.innerHTML = '<span class="preview-empty">Select a product and enter a quantity to see the impact</span>';
                    submitBtn.disabled = true;
                    return;
                }

                if (isNaN(qty) || qty === 0) {
                    const currentStock = parseInt(prodOpt.dataset.stock, 10);
                    previewBox.innerHTML = `
                        <div>Current stock: <strong>${currentStock}</strong></div>
                        <div class="preview-empty">Enter a non-zero quantity to see the result</div>
                    `;
                    submitBtn.disabled = true;
                    return;
                }

                const currentStock = parseInt(prodOpt.dataset.stock, 10);
                const newStock = currentStock + qty;
                const productName = prodOpt.text.split(" — ")[0];

                // Validity checks for the preview
                let validity = "valid";
                let warning  = "";

                if (newStock < 0) {
                    validity = "invalid";
                    warning  = `Cannot go below 0. You can remove at most ${currentStock}.`;
                }

                if (reasonOpt && reasonOpt.value) {
                    const direction = reasonOpt.dataset.direction;
                    if (direction === "negative" && qty > 0) {
                        validity = "invalid";
                        warning  = "Reason requires a NEGATIVE quantity.";
                    } else if (direction === "positive" && qty < 0) {
                        validity = "invalid";
                        warning  = "Reason requires a POSITIVE quantity.";
                    }
                }

                const arrow = qty > 0 ? "↑" : "↓";
                const changeClass = qty > 0 ? "change-positive" : "change-negative";
                const sign = qty > 0 ? "+" : "";

                previewBox.innerHTML = `
                    <div class="preview-product">${escapeHtml(productName)}</div>
                    <div class="preview-flow">
                        <span class="preview-before">${currentStock}</span>
                        <span class="preview-arrow ${changeClass}">${arrow}</span>
                        <span class="preview-after"><strong>${newStock}</strong></span>
                        <span class="change-pill ${changeClass}">${sign}${qty}</span>
                    </div>
                    ${warning ? `<div class="preview-warning">⚠ ${escapeHtml(warning)}</div>` : ""}
                `;

                // Enable submit only if everything checks out
                const reasonPicked = reasonOpt && reasonOpt.value;
                submitBtn.disabled = !(validity === "valid" && reasonPicked);
            }


            function escapeHtml(s) {
                return String(s)
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }


            // Initial state
            updateReasonHint();
            updatePreview();
        })();
    </script>

</body>
</html>
