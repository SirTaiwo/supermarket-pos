<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> &middot; <%= shop.name %></title>
    <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="shop-body">

    <!-- ========== Customer-facing top bar ========== -->
    <header class="shop-topbar">
        <div class="shop-topbar-inner">
            <a href="/shop" class="shop-brand">
                <span class="shop-brand-name"><%= shop.name %></span>
                <% if (shop.tagline) { %>
                    <span class="shop-brand-tagline"><%= shop.tagline %></span>
                <% } %>
            </a>
            <nav class="shop-topnav">
                <a href="/shop">Home</a>
                <a href="/shop/products" class="active">All products</a>
                <a href="/shop/cart" class="shop-cart-link">
                    🛒 Cart
                </a>
            </nav>
        </div>
    </header>

    <!-- ========== Main content ========== -->
    <main class="shop-page">

        <div class="shop-page-header">
            <div>
                <h1 class="shop-page-title">
                    <% if (q) { %>
                        Search: <span class="shop-search-term">"<%= q %>"</span>
                    <% } else { %>
                        All products
                    <% } %>
                </h1>
                <p class="shop-page-subtitle">
                    <% if (products.length === 0) { %>
                        <% if (q) { %>
                            No products matching "<%= q %>"
                        <% } else { %>
                            No products available right now
                        <% } %>
                    <% } else { %>
                        <%= products.length %> product<%= products.length === 1 ? '' : 's' %> available
                    <% } %>
                </p>
            </div>
        </div>

        <!-- ===== Search bar ===== -->
        <form method="GET" action="/shop/products" class="shop-search-form">
            <input
                type="text"
                name="q"
                value="<%= q %>"
                placeholder="Search by name, SKU, or barcode..."
                class="shop-search-input"
                autofocus
            />
            <button type="submit" class="shop-btn-primary">Search</button>
            <% if (q) { %>
                <a href="/shop/products" class="shop-btn-secondary">Clear</a>
            <% } %>
        </form>

        <!-- ===== Products grid ===== -->
        <% if (products.length === 0) { %>

            <div class="shop-empty-state">
                <p class="shop-empty">
                    <% if (q) { %>
                        We don't have anything matching "<strong><%= q %></strong>" right now.
                        Try a different search, or browse all products.
                    <% } else { %>
                        We're updating our catalogue. Please check back soon.
                    <% } %>
                </p>
                <% if (q) { %>
                    <a href="/shop/products" class="shop-btn-primary">Browse all products</a>
                <% } %>
            </div>

        <% } else { %>

            <div class="shop-product-grid">
                <% products.forEach(p => { %>
                    <div class="shop-product-card <%= p.stock_qty === 0 ? 'shop-product-card-empty' : '' %>">
                        <div class="shop-product-name"><%= p.name %></div>
                        <div class="shop-product-sku"><%= p.sku %></div>
                        <div class="shop-product-price">
                            <%= formatRand(p.price_cents) %>
                            <span class="shop-product-vat">incl. VAT</span>
                        </div>
                        <div class="shop-product-stock">
                            <% if (p.stock_qty === 0) { %>
                                <span class="stock-pill stock-out">Out of stock</span>
                            <% } else if (p.stock_qty <= 5) { %>
                                <span class="stock-pill stock-low">Only <%= p.stock_qty %> left</span>
                            <% } else if (p.stock_qty <= 20) { %>
                                <span class="stock-pill stock-good"><%= p.stock_qty %> in stock</span>
                            <% } else { %>
                                <span class="stock-pill stock-good">In stock</span>
                            <% } %>
                        </div>
                        <% if (p.stock_qty > 0) { %>
                            <form method="POST" action="/shop/cart/add" class="shop-product-add-form">
                                <input type="hidden" name="product_id" value="<%= p.id %>" />
                                <button type="submit" class="shop-btn-primary shop-add-btn" disabled title="Cart coming next session">
                                    Add to cart
                                </button>
                            </form>
                        <% } else { %>
                            <button class="shop-btn-secondary shop-add-btn" disabled>Out of stock</button>
                        <% } %>
                    </div>
                <% }) %>
            </div>

        <% } %>

    </main>

    <footer class="shop-footer">
        <div class="shop-footer-inner">
            <span>&copy; 2026 <%= shop.name %></span>
            <a href="/login" class="shop-staff-link">Staff login</a>
        </div>
    </footer>

</body>
</html>
