<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> &middot; Supermarket POS</title>
    <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>

    <!-- ========== Top bar ========== -->
    <header class="topbar">
        <div class="topbar-inner">
            <a href="/" class="brand">
                <span class="brand-mark">▤</span>
                <span class="brand-name">Supermarket POS</span>
            </a>
            <nav class="topnav">
                <a href="/pos">Till</a>
                <a href="/products">Products</a>
                <a href="/suppliers">Suppliers</a>
                <a href="/grn">Goods received</a>
                <a href="/returns">Refunds</a>
                <a href="/stock-adjustments">Adjustments</a>
                <a href="/shifts/current" class="active">Shifts</a>
                <a href="/reports/daily">Reports</a>
                <a href="/users">Users</a>
            </nav>
            <div class="topbar-user">
                <span class="user-name"><%= currentUser.full_name %></span>
                <span class="user-role"><%= currentUser.role %></span>
                <a href="/logout" class="logout-link">Sign out</a>
            </div>
        </div>
    </header>

    <!-- ========== Flash ========== -->
    <% if (flashError && flashError.length > 0) { %>
        <div class="flash flash-error"><%= flashError[0] %></div>
    <% } %>

    <!-- ========== Main content ========== -->
    <main class="page">

        <div class="form-page">

            <div class="form-header">
                <h1>Open shift</h1>
                <a href="/shifts/current" class="form-back">← Back</a>
            </div>

            <p class="page-subtitle">
                Count the cash currently in the till drawer and enter the
                amount below. This is your "opening float" — the system uses
                it as the starting point for reconciliation at end of shift.
            </p>

            <form method="POST" action="/shifts" class="product-form">

                <div class="form-grid">

                    <label class="field field-full">
                        <span class="field-label">Opening float (Rand) <span class="req">*</span></span>
                        <input
                            type="number"
                            name="opening_float"
                            required
                            min="0"
                            step="0.01"
                            placeholder="e.g. 500.00"
                            autofocus
                        />
                        <span class="field-hint">
                            Enter in Rand, e.g. 500.00 for R 500. Common values are
                            R 200, R 500, or R 1,000 depending on shop policy.
                        </span>
                    </label>

                </div>

                <div class="form-actions">
                    <a href="/shifts/current" class="btn-secondary">Cancel</a>
                    <button type="submit" class="btn-primary">Open shift</button>
                </div>

            </form>

            <div class="form-side-notes">
                <p>
                    Once opened, all your sales and refunds will be tracked under
                    this shift. You can have only one open shift at a time — close
                    this one before starting another.
                </p>
            </div>

        </div>

    </main>

    <footer class="sitefoot">
        <span>Supermarket POS &middot; Phase 3</span>
        <span>&copy; 2026</span>
    </footer>

</body>
</html>
