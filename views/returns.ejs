<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> &middot; Supermarket POS</title>
    <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>

    <!-- ========== Top bar ========== -->
    <header class="topbar">
        <div class="topbar-inner">
            <a href="/" class="brand">
                <span class="brand-mark">▤</span>
                <span class="brand-name">Supermarket POS</span>
            </a>
            <nav class="topnav">
                <a href="/pos">Till</a>
                <a href="/products">Products</a>
                <a href="/suppliers">Suppliers</a>
                <a href="/grn">Goods received</a>
                <a href="/returns" class="active">Refunds</a>
                <a href="/stock-adjustments">Adjustments</a>
                <a href="/reports/daily">Reports</a>
                <a href="/users">Users</a>
            </nav>
            <div class="topbar-user">
                <span class="user-name"><%= currentUser.full_name %></span>
                <span class="user-role"><%= currentUser.role %></span>
                <a href="/logout" class="logout-link">Sign out</a>
            </div>
        </div>
    </header>

    <!-- ========== Flash ========== -->
    <% if (flashSuccess && flashSuccess.length > 0) { %>
        <div class="flash flash-success"><%= flashSuccess[0] %></div>
    <% } %>
    <% if (flashError && flashError.length > 0) { %>
        <div class="flash flash-error"><%= flashError[0] %></div>
    <% } %>

    <!-- ========== Main content ========== -->
    <main class="page">

        <div class="page-header">
            <div>
                <h1>Refunds</h1>
                <p class="page-subtitle">
                    <% if (refunds.length === 0) { %>
                        No refunds recorded yet
                    <% } else { %>
                        <%= refunds.length %> refund<%= refunds.length === 1 ? '' : 's' %> recorded
                    <% } %>
                </p>
            </div>
            <a href="/returns/new" class="btn-primary">+ Process refund</a>
        </div>

        <% if (refunds.length === 0) { %>

            <div class="empty-state">
                <p>
                    Process customer refunds here. Each refund is linked to an
                    original sale, returns stock to the shelf, and is recorded
                    against the original transaction for a complete audit trail.
                </p>
                <a href="/returns/new" class="btn-primary">Process your first refund</a>
            </div>

        <% } else { %>

            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Reference</th>
                            <th>When</th>
                            <th>Original sale</th>
                            <th class="num">Lines</th>
                            <th class="num">Units</th>
                            <th class="num">Refunded</th>
                            <th>Reason</th>
                            <th>By</th>
                            <th class="actions-col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% refunds.forEach(r => { %>
                            <tr>
                                <td>
                                    <div class="cell-name"><%= r.reference %></div>
                                </td>
                                <td>
                                    <div><%= formatDate(r.created_at) %></div>
                                </td>
                                <td>
                                    <div class="cell-meta cell-meta-mono"><%= r.original_sale_reference %></div>
                                </td>
                                <td class="num"><%= r.line_count %></td>
                                <td class="num"><%= r.total_units || 0 %></td>
                                <td class="num">
                                    <strong class="amount-refund">-<%= formatRand(r.total_cents) %></strong>
                                </td>
                                <td>
                                    <% if (r.reason) { %>
                                        <div class="cell-meta"><%= r.reason %></div>
                                    <% } else { %>
                                        <span class="cell-meta">—</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="cell-meta"><%= r.cashier_name %></div>
                                </td>
                                <td class="actions-col">
                                    <a href="/returns/<%= r.id %>" class="btn-tiny">View</a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

        <% } %>

    </main>

    <footer class="sitefoot">
        <span>Supermarket POS &middot; Phase 3</span>
        <span>&copy; 2026</span>
    </footer>

</body>
</html>
